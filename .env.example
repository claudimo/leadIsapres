# ============================================================
# ISAPRE INTELIGENTE - Configuración del servidor
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=production

# --- Email SMTP (para recibir los leads) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_gmail

# --- Destinatario de los leads ---
LEAD_EMAIL_TO=ventas@isapreinteligente.cl
LEAD_EMAIL_FROM="Isapre Inteligente <noreply@isapreinteligente.cl>"

# --- WhatsApp (número con código de país, sin +) ---
WHATSAPP_NUMBER=56912345678
WHATSAPP_MESSAGE=Hola,%20quiero%20cotizar%20mi%20plan%20de%20Isapre

# --- Seguridad ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# --- Almacenamiento local de leads ---
SAVE_LEADS_TO_FILE=true
LEADS_FILE_PATH=./data/leads.json
